---
---
<button
    id="theme-toggle"
    type="button"
    aria-label="Toggle dark mode"
    aria-pressed="false"
    class="flex items-center justify-center w-10 h-10 transition-colors duration-200 hover:bg-black/5 dark:hover:bg-white/10"
>
    <!-- Sun icon (visible in dark mode) -->
    <svg
        class="w-5 h-5 hidden dark:block"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <!-- Moon icon (visible in light mode) -->
    <svg
        class="w-5 h-5 block dark:hidden"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
</button>

<script>
    const toggle = document.getElementById("theme-toggle");
    const root = document.documentElement;
    /** @type {MediaQueryList | null} */
    const mediaQuery = (() => {
        try {
            return matchMedia("(prefers-color-scheme: dark)");
        } catch {
            return null;
        }
    })();

    function safeGetTheme() {
        try {
            return localStorage.getItem("theme");
        } catch {
            return null;
        }
    }

    function safeSetDarkTheme() {
        try {
            localStorage.setItem("theme", "dark");
        } catch {
            // Storage unavailable (private mode, etc.) - fail silently
        }
    }

    function safeSetLightTheme() {
        try {
            localStorage.setItem("theme", "light");
        } catch {
            // Storage unavailable (private mode, etc.) - fail silently
        }
    }

    function hasExplicitUserTheme() {
        const theme = safeGetTheme();
        return theme === "dark" || theme === "light" || root.dataset.userThemeExplicit === "true";
    }

    function applyDarkThemeClass() {
        root.classList.add("dark");
    }

    function applyLightThemeClass() {
        root.classList.remove("dark");
    }

    function syncAriaPressed() {
        const isDark = root.classList.contains("dark");
        toggle?.setAttribute("aria-pressed", String(isDark));
    }

    toggle?.addEventListener("click", () => {
        if (root.dataset.themeTransitionTimeoutId) {
            clearTimeout(Number(root.dataset.themeTransitionTimeoutId));
        }

        root.classList.add("theme-transition");

        try {
            if (root.classList.contains("dark")) {
                applyLightThemeClass();
                safeSetLightTheme();
            } else {
                applyDarkThemeClass();
                safeSetDarkTheme();
            }

            root.dataset.userThemeExplicit = "true";
        } finally {
            const nextTimeoutId = setTimeout(() => {
                root.classList.remove("theme-transition");
                delete root.dataset.themeTransitionTimeoutId;
            }, 350);
            root.dataset.themeTransitionTimeoutId = String(nextTimeoutId);
        }

        syncAriaPressed();
    });

    function handleSystemThemeChange() {
        if (hasExplicitUserTheme() || !mediaQuery) {
            return;
        }

        if (mediaQuery.matches) {
            applyDarkThemeClass();
        } else {
            applyLightThemeClass();
        }

        syncAriaPressed();
    }

    syncAriaPressed();

    if (root.dataset.themeListenerMounted !== "true" && mediaQuery) {
        root.dataset.themeListenerMounted = "true";
        mediaQuery.addEventListener("change", handleSystemThemeChange);
    }
</script>
